PORT=3000
LOG_LEVEL=info
DATA_DIR=data
API_SECRET=replace-with-long-random-token
DEMO_PUBLIC=false
ENABLED_STRATEGIES=dex-arbitrage
ENGINE_INTERVAL_MS=5000
QUOTE_STALE_MS=1000
WS_ENABLED=false
WS_URL=
WS_RECONNECT_MS=2000
PAIR=ETH/USDC
DEX_A=okx-dex-a
DEX_B=okx-dex-b
START_MODE=paper
# SECURITY RISK: true means engine can run in live mode with real execution.
LIVE_ENABLED=false
# SECURITY RISK: true allows automatic promotion from paper to live when gate passes.
AUTO_PROMOTE_TO_LIVE=false
PAPER_START_BALANCE_USD=10000
LIVE_BALANCE_USD=3000
MIN_NET_EDGE_BPS_PAPER=45
MIN_NET_EDGE_BPS_LIVE=60
MAX_TRADE_PCT_BALANCE=0.03
MAX_DAILY_LOSS_PCT=0.015
MAX_CONSECUTIVE_FAILURES=3
SLIPPAGE_BPS=12
TAKER_FEE_BPS=20
GAS_USD_DEFAULT=1.25
MEV_PENALTY_BPS=5
LIQUIDITY_USD_DEFAULT=250000
VOLATILITY_DEFAULT=0.02
AVG_LATENCY_MS_DEFAULT=250
EVAL_NOTIONAL_USD_DEFAULT=1000
DISCOVERY_DEFAULT_DURATION_MINUTES=30
DISCOVERY_DEFAULT_SAMPLE_INTERVAL_SEC=5
DISCOVERY_DEFAULT_TOPN=20
DISCOVERY_LOOKBACK_SAMPLES=60
DISCOVERY_Z_ENTER=2
DISCOVERY_VOL_RATIO_MIN=1.8
DISCOVERY_MIN_SPREAD_BPS=35
DISCOVERY_NOTIONAL_USD=1000
ONCHAINOS_API_BASE=
ONCHAINOS_API_KEY=
ONCHAINOS_API_SECRET=
ONCHAINOS_PASSPHRASE=
ONCHAINOS_PROJECT_ID=
ONCHAINOS_AUTH_MODE=bearer
ONCHAINOS_API_KEY_HEADER=X-API-Key
ONCHAINOS_CHAIN_INDEX=196
ONCHAINOS_REQUIRE_SIMULATE=true
ONCHAINOS_ENABLE_COMPAT_FALLBACK=true
ONCHAINOS_TOKEN_CACHE_TTL_SECONDS=600
ONCHAINOS_TOKEN_PROFILE_PATH=/api/v6/market/token/profile/current
# Agent-Comm v0.1 (single-chain, poll-only)
COMM_ENABLED=false
COMM_CHAIN_ID=196
COMM_RPC_URL=
# supported values: disabled | poll
COMM_LISTENER_MODE=disabled
COMM_POLL_INTERVAL_MS=5000
COMM_WALLET_ALIAS=agent-comm
# when COMM_ENABLED=true, VAULT_MASTER_PASSWORD must be provided at startup
# optional placeholders (not in v0.1 acceptance scope)
COMM_PAYMASTER_URL=
X402_MODE=disabled
# optional values for scripts/onchainos-live-smoke.sh
